# Ignore operating system files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode/
.idea/
*.iml

# Ignore node_modules (if you're using npm)
node_modules/

# Ignore logs and temp files
logs/
tmp/
*.log
*.tmp

# Ignore compiled files (e.g. minified CSS/JS)
*.min.css
*.min.js

# Ignore database files (if you're using a local database)
db.sqlite3

# Ignore uploads (if you have a file upload feature)
uploads/
